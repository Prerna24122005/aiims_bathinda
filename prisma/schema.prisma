// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEDICAL_STAFF
  SCHOOL_POC
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum EventStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  LOCKED
  CANCELED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum RecordStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model User {
  id            String             @id @default(uuid())
  email         String             @unique
  passwordHash  String
  fullName      String
  role          Role               @default(MEDICAL_STAFF)
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  createdEvents Event[]            @relation("EventCreator")
  assignedEvents EventStaff[]
  auditLogs     CategoryAuditLog[]
}

model HealthCampRequest {
  id                String        @id @default(uuid())
  schoolName        String
  pocName           String
  pocEmail          String
  pocPhone          String
  tentativeDate     DateTime
  tentativeStudents Int
  status            RequestStatus @default(PENDING)
  rejectionReason   String?       @db.Text
  createdAt         DateTime      @default(now())
}

model Event {
  id            String       @id @default(uuid())
  schoolDetails String
  eventDate     DateTime
  pocName       String
  pocEmail      String
  pocPhone      String
  status        EventStatus  @default(UPCOMING)
  formConfig    Json?        @default("{}")
  createdBy     String
  creator       User         @relation("EventCreator", fields: [createdBy], references: [id])
  createdAt     DateTime     @default(now())
  eventStaff    EventStaff[]
  students      Student[]
  medicalRecords MedicalRecord[]
}

model EventStaff {
  eventId String
  userId  String
  event   Event  @relation(fields: [eventId], references: [id])
  user    User   @relation(fields: [userId], references: [id])

  @@id([eventId, userId])
}

model Student {
  id             String         @id @default(uuid())
  eventId        String
  firstName      String
  lastName       String
  classSec       String
  age            Int
  gender         Gender
  schoolIdNumber String?
  event          Event          @relation(fields: [eventId], references: [id])
  medicalRecord  MedicalRecord?

  @@unique([eventId, firstName, lastName, classSec])
}

model MedicalRecord {
  id          String             @id @default(uuid())
  studentId   String             @unique
  eventId     String
  status      RecordStatus       @default(PENDING)
  data        Json               @default("{}")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  student     Student            @relation(fields: [studentId], references: [id])
  event       Event              @relation(fields: [eventId], references: [id])
  auditLogs   CategoryAuditLog[]
}

model CategoryAuditLog {
  id              String        @id @default(uuid())
  medicalRecordId String
  userId          String
  categoryName    String
  timestamp       DateTime      @default(now())
  action          String        @default("SAVED") // SAVED, OVERRIDDEN
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
}
